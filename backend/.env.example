# Copy this file to .env for local testing (Render/Railway: set these in their dashboard instead)

# Admin login for /admin dashboard
ADMIN_USER=admin
ADMIN_PASS=change-this-password

# Where the SQLite database file lives.
# On Render/Railway, point this at a mounted persistent disk/volume, e.g. /data/conference.db
# Locally, the default (./data/conference.db) is fine.
DB_PATH=./data/conference.db
